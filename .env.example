# ============================================================
# OpenChamber Docker — Variables de Entorno Runtime
# Copiar a .env y personalizar:
#   cp .env.example .env
# ============================================================

# =====================
# OpenChamber — Core
# =====================

# Puerto host para UI web de OpenChamber
# Default: 3000
OPENCHAMBER_PORT=3000

# Dirección de bind dentro del contenedor
# Default: 0.0.0.0 (todas las interfaces)
OPENCHAMBER_HOST=0.0.0.0

# Contraseña UI (recomendada: fuerte, para cloud/VPS)
# Si está vacía, OpenChamber inicia sin protección
UI_PASSWORD=

# Alternativa upstream a UI_PASSWORD
# Se usa como fallback si UI_PASSWORD no está definida
OPENCHAMBER_UI_PASSWORD=

# Directorio de configuración OpenCode gestionado por el entrypoint
# Default: ~/.config/opencode (mapeado a ./data/opencode/config)
OPENCHAMBER_CONFIG_DIR=

# Directorio de datos OpenChamber (opcional)
# Default: ~/.config/openchamber (mapeado a ./data/openchamber)
OPENCHAMBER_DATA_DIR=

# =====================
# OpenCode — Bridge
# =====================

# Hostname para servidor OpenCode embebido
OPENCHAMBER_OPENCODE_HOSTNAME=0.0.0.0

# Host del servidor OpenCode externo (opcional)
OPENCODE_HOST=

# Puerto del servidor OpenCode externo (opcional)
OPENCODE_PORT=

# Saltar inicio automático de OpenCode
# Útil cuando OpenCode corre como servicio separado
OPENCODE_SKIP_START=false

# =====================
# GitHub / Auth
# =====================

# Token GitHub para autenticación headless en VPS
# Necesario para features que requieren API de GitHub
GH_TOKEN=

# =====================
# Cloudflare Tunnel
# =====================

# Proveedor de túnel (cloudflare por ahora)
OPENCHAMBER_TUNNEL_PROVIDER=

# Modo de túnel (por ejemplo: cloudflared)
OPENCHAMBER_TUNNEL_MODE=

# Hostname público del túnel (ej: openchamber.midominio.com)
OPENCHAMBER_TUNNEL_HOSTNAME=

# Token de autenticación del túnel
OPENCHAMBER_TUNNEL_TOKEN=

# Ruta a archivo de configuración del túnel
OPENCHAMBER_TUNNEL_CONFIG=

# =====================
# Misceláneo
# =====================

# Upstream oh-my-opencode
# Activa funciones extra de la comunidad
OH_MY_OPENCODE=false

# ============================================================
# NOTA: Build Args (NO son variables runtime)
#
#   OPENCHAMBER_VERSION  — versión de OpenChamber
#   OPENCODE_VERSION     — versión de OpenCode
#
# Estas NO deben estar en .env. Se pasan como build args en
# docker-compose.yml > build.args y tienen defaults en Dockerfile.
# No afectan el comportamiento runtime del contenedor.
# ============================================================
